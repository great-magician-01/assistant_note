# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=cloudnote
DB_PASSWORD=
DB_NAME=amanuensis
DB_SCHEMA=public
# 生产环境请设置为 require 或 verify-full
DB_SSLMODE=require
SQLITE_PATH="./cache/sqlite.db"


# JWT 签名密钥（必须设置，建议 32+ 字符随机字符串）
ACCESS_JWT_SECRET=

REFRESH_JWT_SECRET=


# 服务端口
BACKEND_SERVER_PORT=6581
FRONTEND_SERVER_PORT=6580

# 日志目录
LOG_DIR=pylogs



# Debug 模式（true 时日志级别为 Debug，会输出所有 SQL 语句和参数）
DEBUG=false


# CORS 允许的来源（逗号分隔，生产环境请设置具体域名，而非 *）
CORS_ALLOW_ORIGINS=*


# AI 配置

# OPENAI / ANTHROPIC 
AI_TYPE=

API_KEY=

API_BASE=

AI_MODEL=

