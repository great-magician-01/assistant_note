# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=cloudnote
DB_PASSWORD=
DB_NAME=amanuensis
DB_SCHEMA=public
# 生产环境请设置为 require 或 verify-full
DB_SSLMODE=require
SQLITE_PATH="./cache/sqlite.db"


# JWT 签名密钥（必须设置，建议 32+ 字符随机字符串）
ACCESS_JWT_SECRET=

REFRESH_JWT_SECRET=


# 服务端口
BACKEND_SERVER_PORT=6581
FRONTEND_SERVER_PORT=6580

# 日志目录
LOG_DIR=pylogs



# Debug 模式（true 时日志级别为 Debug，会输出所有 SQL 语句和参数）
DEBUG=false


# CORS 允许的来源（逗号分隔，生产环境请设置具体域名，而非 *）
CORS_ALLOW_ORIGINS=*

# 管理员账号 — 启动时自动注册/确保存在并设为管理员(每次启动重置密码)
# 留空则跳过管理员引导
ADMIN_ACCOUNT=
ADMIN_PASSWORD=

# 图片上传 — 存储目录(相对项目根),按 user_id 隔离;公开静态服务
UPLOAD_DIR=uploads
UPLOAD_BASE_URL=/uploads
UPLOAD_MAX_SIZE_MB=10
# 允许的扩展名(逗号分隔,不含点);默认不含 svg(直接访问 svg URL 会执行其中的脚本)
UPLOAD_ALLOWED_EXT=png,jpg,jpeg,gif,webp

